# === LinkCloud Configuration ===

# Database password (change this!)
DB_PASSWORD=super-secret-db-password-change-me

# JWT Secret for admin authentication (change this!)
JWT_SECRET=change-me-to-a-long-random-string-abc123xyz

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Your domain (used in nginx config)
DOMAIN=yourdomain.com

# Port (don't change unless you know what you're doing)
PORT=3000
NODE_ENV=production
